# /usr/lib/udev/rules.d/99-thunderbolt-pm.rules

# Enable power management for Thunderbolt controllers and ports
#ACTION=="add", SUBSYSTEM=="pci", KERNEL=="0000:05:00.0", ATTR{power/control}="auto"
#ACTION=="add", SUBSYSTEM=="pci", KERNEL=="0000:06:00.0", ATTR{power/control}="auto"
#ACTION=="add", SUBSYSTEM=="pci", KERNEL=="0000:06:03.0", ATTR{power/control}="auto"
#ACTION=="add", SUBSYSTEM=="pci", KERNEL=="0000:06:04.0", ATTR{power/control}="auto"
#ACTION=="add", SUBSYSTEM=="pci", KERNEL=="0000:06:05.0", ATTR{power/control}="auto"
ACTION=="add", SUBSYSTEM=="pci", KERNEL=="0000:07:00.0", ATTR{power/control}="auto"
