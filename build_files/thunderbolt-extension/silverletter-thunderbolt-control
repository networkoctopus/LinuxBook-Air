#!/bin/bash
# Privileged backend for manual, boot-scoped Thunderbolt control.
set -euo pipefail

readonly STATE_DIR="/run/silverletter"
readonly STATE_FILE="${STATE_DIR}/thunderbolt.state"
readonly CONTROL_LOCK="${STATE_DIR}/thunderbolt-control.lock"
readonly POWERDOWN_LOCK="/run/tb-powerdown.lock"
readonly POWERDOWN_HELPER="/usr/libexec/tb-powerdown.sh"
readonly RUNTIME_RULE_DIR="/run/udev/rules.d"
readonly POWERDOWN_MASK="${RUNTIME_RULE_DIR}/99-thunderbolt-pm.rules"
readonly RUNTIME_MODPROBE_DIR="/run/modprobe.d"
readonly BLACKLIST_MASK="${RUNTIME_MODPROBE_DIR}/thunderbolt-blacklist.conf"
readonly ROOT_PORT_WAKE="/sys/bus/pci/devices/0000:00:1c.4/power/wakeup"
readonly LOG_TAG="silverletter-thunderbolt"
readonly -a TB_DEVICES=(
    07:00.0
    06:06.0
    06:05.0
    06:04.0
    06:03.0
    06:00.0
    05:00.0
)

log_event() {
    local priority="$1"
    shift
    logger -p "$priority" -t "$LOG_TAG" -- "$*" || true
}

notify_state() {
    local state="$1"

    if ! {
        install -d -m 0755 "$STATE_DIR" &&
        printf '%s\n' "$state" > "$STATE_FILE" &&
        chmod 0644 "$STATE_FILE"
    }; then
        log_event daemon.warning \
            "action=state-notify result=failed requested_state=$state"
    fi
}

require_root() {
    if [[ $EUID -ne 0 ]]; then
        printf 'This operation requires administrator privileges.\n' >&2
        exit 1
    fi
}

nhi_present() {
    [[ -e /sys/bus/pci/devices/0000:07:00.0 ]]
}

thunderbolt_hierarchy_present() {
    local device

    for device in "${TB_DEVICES[@]}"; do
        if [[ -e "/sys/bus/pci/devices/0000:$device" ]]; then
            return 0
        fi
    done

    return 1
}

thunderbolt_storage_present() {
    local block_path device_path

    for block_path in /sys/class/block/*; do
        [[ -e "$block_path" ]] || continue
        device_path="$(readlink -f "$block_path")"
        if [[ "$device_path" == *"/0000:05:00.0/"* ]]; then
            return 0
        fi
    done

    return 1
}

session_enabled() {
    [[ -L "$POWERDOWN_MASK" &&
       "$(readlink "$POWERDOWN_MASK")" == "/dev/null" ]]
}

show_status() {
    if thunderbolt_hierarchy_present || [[ -d /sys/module/thunderbolt ]]; then
        printf 'active\n'
    elif session_enabled; then
        printf 'armed\n'
    else
        printf 'disabled\n'
    fi
}

mask_powerdown_rule() {
    install -d -m 0755 \
        "$STATE_DIR" \
        "$RUNTIME_RULE_DIR" \
        "$RUNTIME_MODPROBE_DIR"

    # Same-named /dev/null links in /run override the image's power-down rule
    # and module blacklist until manual disable or the next reboot. This lets
    # normal PCI modalias processing reload thunderbolt after system sleep.
    ln -sfn /dev/null "$POWERDOWN_MASK"
    ln -sfn /dev/null "$BLACKLIST_MASK"

    udevadm control --reload-rules
    log_event daemon.info \
        "action=enable stage=runtime-policy-installed lifetime=until-disable-or-reboot"
}

remove_powerdown_mask() {
    rm -f "$POWERDOWN_MASK" "$BLACKLIST_MASK"
    udevadm control --reload-rules || true
}

disable_root_port_wake() {
    # 00:1c.4 exclusively owns the Thunderbolt hierarchy on this platform.
    # Disabling its PCI wake capability is precautionary and must not make
    # suspend fail if the firmware does not expose a writable wake attribute.
    if [[ ! -w "$ROOT_PORT_WAKE" ]]; then
        log_event daemon.warning \
            "action=prepare-suspend stage=root-port-wake result=skipped path=$ROOT_PORT_WAKE"
        return 0
    fi

    if printf 'disabled\n' > "$ROOT_PORT_WAKE"; then
        log_event daemon.info \
            "action=prepare-suspend stage=root-port-wake state=disabled device=0000:00:1c.4"
    else
        log_event daemon.warning \
            "action=prepare-suspend stage=root-port-wake result=failed device=0000:00:1c.4"
    fi
}

enable_thunderbolt() {
    local attempt powerdown_lock_acquired=0

    rollback_enable() {
        local status=$?
        trap - ERR
        log_event daemon.err "action=enable result=failed exit_status=$status"
        remove_powerdown_mask
        if (( powerdown_lock_acquired )); then
            flock -u 8 || true
        fi
        modprobe -r thunderbolt 2>/dev/null || true
        "$POWERDOWN_HELPER" || true
        notify_state disabled
        exit "$status"
    }
    trap rollback_enable ERR

    log_event daemon.notice \
        "action=enable stage=start lifetime=until-disable-or-reboot"
    mask_powerdown_rule

    # Let every udev job that was queued under the image rule finish. The
    # power-down helper is deliberately not cancellable, so manual activation
    # always starts from the same fully removed PCI state.
    if ! udevadm settle --timeout=30; then
        printf 'Timed out waiting for the boot Thunderbolt power-down to finish.\n' >&2
        return 1
    fi
    log_event daemon.info "action=enable stage=boot-powerdown-settled"

    # Serialize with the helper as a final guard before PCI rescan.
    exec 8> "$POWERDOWN_LOCK"
    flock 8
    powerdown_lock_acquired=1
    log_event daemon.info "action=enable stage=powerdown-lock-acquired"

    modprobe thunderbolt
    log_event daemon.info "action=enable stage=module-loaded module=thunderbolt"

    printf '1\n' > /sys/bus/pci/rescan
    log_event daemon.info "action=enable stage=pci-rescan"
    udevadm settle --timeout=10 || true

    for attempt in {1..20}; do
        if nhi_present; then
            break
        fi
        sleep 0.5
    done

    if ! nhi_present; then
        # Falcon Ridge may not wake from its removed low-power state until it
        # sees a new physical hot-plug edge. Keep this boot-scoped session
        # armed and let a disconnect/reconnect perform the safe hardware wake.
        flock -u 8
        powerdown_lock_acquired=0
        trap - ERR
        log_event daemon.notice \
            "action=enable result=success state=armed controller=absent reconnect_required=yes lifetime=until-disable-or-reboot"
        notify_state armed
        printf 'armed\n'
        return 0
    fi

    flock -u 8
    powerdown_lock_acquired=0
    trap - ERR
    log_event daemon.notice \
        "action=enable result=success state=active controller=0000:07:00.0 lifetime=until-disable-or-reboot"
    notify_state active
    printf 'active\n'
}

teardown_thunderbolt() {
    local action="$1"
    local preserve_session=0
    local was_enabled=0

    if session_enabled; then
        was_enabled=1
    fi

    if [[ "$action" == prepare-suspend ]] && (( was_enabled )); then
        preserve_session=1
    fi

    restore_session_after_failure() {
        if (( was_enabled )); then
            install -d -m 0755 \
                "$STATE_DIR" \
                "$RUNTIME_RULE_DIR" \
                "$RUNTIME_MODPROBE_DIR"
            ln -sfn /dev/null "$POWERDOWN_MASK"
            ln -sfn /dev/null "$BLACKLIST_MASK"
            udevadm control --reload-rules || true
            log_event daemon.warning \
                "action=$action stage=runtime-policy-restored reason=teardown-failed"
        fi
    }

    log_event daemon.notice "action=$action stage=start"

    # Arbitrary storage cannot be safely unmounted by this privileged backend.
    # Refuse the operation without changing session state; after the user
    # ejects or disconnects the drive, disable or suspend can be retried.
    if thunderbolt_storage_present; then
        log_event daemon.err \
            "action=$action result=failed reason=thunderbolt-storage-attached"
        printf 'Eject or disconnect Thunderbolt storage before disabling Thunderbolt.\n' >&2
        return 1
    fi

    if (( preserve_session )); then
        # Preserve the enabled session across sleep. Ensure both runtime masks
        # are present so normal modalias handling can reload thunderbolt when
        # Falcon Ridge naturally re-enumerates after resume.
        install -d -m 0755 "$RUNTIME_RULE_DIR" "$RUNTIME_MODPROBE_DIR"
        ln -sfn /dev/null "$POWERDOWN_MASK"
        ln -sfn /dev/null "$BLACKLIST_MASK"
        udevadm control --reload-rules
        log_event daemon.info \
            "action=$action stage=runtime-policy-preserved state=armed"
    else
        # Manual disable restores the image's default power-down rule and
        # module blacklist before touching the PCI hierarchy.
        remove_powerdown_mask
        log_event daemon.info \
            "action=$action stage=default-policy-restored"
    fi

    if ! udevadm settle --timeout=30; then
        log_event daemon.err "action=$action result=failed reason=udev-timeout"
        printf 'Timed out waiting for Thunderbolt device events to finish.\n' >&2
        restore_session_after_failure
        return 1
    fi

    # Remove the optional networking layer first so that it cannot retain the
    # core Thunderbolt module during PCI hot-removal.
    if [[ -d /sys/module/thunderbolt_net ]]; then
        if ! modprobe -r thunderbolt_net; then
            log_event daemon.err \
                "action=$action result=failed reason=module-in-use module=thunderbolt_net"
            printf 'Thunderbolt networking is still in use.\n' >&2
            restore_session_after_failure
            return 1
        fi
        log_event daemon.info \
            "action=$action stage=module-removed module=thunderbolt_net"
    fi

    if thunderbolt_hierarchy_present; then
        # The proven boot helper first requests runtime suspend and then uses
        # the PCI remove interface. PCI core removal invokes the normal remove
        # callbacks for any downstream adapter before removing its bridges.
        if ! "$POWERDOWN_HELPER"; then
            log_event daemon.err \
                "action=$action result=failed reason=powerdown-helper-failed"
            printf 'The Thunderbolt power-down helper failed.\n' >&2
            restore_session_after_failure
            return 1
        fi
        udevadm settle --timeout=30 || true
    fi

    if thunderbolt_hierarchy_present; then
        log_event daemon.err \
            "action=$action result=failed reason=pci-hierarchy-remains"
        printf 'The Thunderbolt PCI hierarchy could not be fully removed.\n' >&2
        restore_session_after_failure
        return 1
    fi

    if [[ -d /sys/module/thunderbolt ]]; then
        if ! modprobe -r thunderbolt; then
            log_event daemon.err \
                "action=$action result=failed reason=module-in-use module=thunderbolt"
            printf 'The Thunderbolt driver is still in use.\n' >&2
            restore_session_after_failure
            return 1
        fi
        log_event daemon.info \
            "action=$action stage=module-removed module=thunderbolt"
    fi

    if (( preserve_session )); then
        log_event daemon.notice \
            "action=$action result=success state=armed resume=automatic-or-reconnect"
        notify_state armed
    else
        log_event daemon.notice \
            "action=$action result=success state=powered-down reenable=manual"
        notify_state disabled
    fi
}

disable_thunderbolt() {
    teardown_thunderbolt disable
    printf 'disabled\n'
}

prepare_suspend() {
    disable_root_port_wake
    teardown_thunderbolt prepare-suspend
}

case "${1:-}" in
    status)
        show_status
        ;;
    enable)
        require_root
        install -d -m 0755 "$STATE_DIR"
        exec 9> "$CONTROL_LOCK"
        flock 9
        enable_thunderbolt
        ;;
    disable)
        require_root
        install -d -m 0755 "$STATE_DIR"
        exec 9> "$CONTROL_LOCK"
        flock 9
        disable_thunderbolt
        ;;
    prepare-suspend)
        require_root
        install -d -m 0755 "$STATE_DIR"
        exec 9> "$CONTROL_LOCK"
        flock 9
        prepare_suspend
        ;;
    *)
        printf 'Usage: %s {status|enable|disable|prepare-suspend}\n' "$0" >&2
        exit 2
        ;;
esac
